<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.BudgetBook.infrastructure.persistence.mapper.CategoryCustomMapper">

    <select id="selectByIds" resultType="com.example.BudgetBook.infrastructure.persistence.entity.CategoryEntity">
        SELECT
        id,
        user_id,
        name,
        type,
        color,
        sort_order,
        is_default,
        created_at
        FROM categories
        WHERE id IN
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id,jdbcType=OTHER,typeHandler=org.apache.ibatis.type.ObjectTypeHandler}
        </foreach>
    </select>

</mapper>